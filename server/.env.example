# ──────────────────────────────────────────────────────────
# Spider-Lens — Configuration serveur
# Copiez ce fichier en .env et adaptez les valeurs
# ──────────────────────────────────────────────────────────

# ── Serveur ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Sécurité (OBLIGATOIRE : changez en production) ────────
# Générez une clé forte : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez-ce-secret-en-production-avec-une-cle-longue-et-aleatoire

# ── Compte admin (modifiable depuis les Paramètres) ───────
ADMIN_USER=admin
ADMIN_PASS=changez-ce-mot-de-passe

# ── Fichier de log à analyser ─────────────────────────────
# Apache : /var/log/apache2/access.log
# Nginx  : /var/log/nginx/access.log
LOG_FILE_PATH=/var/log/nginx/access.log

# ── Base de données SQLite ────────────────────────────────
DB_PATH=./spider-lens.db
