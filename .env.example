# Spider-Lens — Configuration
# Copier ce fichier en .env et remplir les valeurs

# ── Application ──────────────────────────────────
PORT=3000
NODE_ENV=production
# Générer avec : openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_openssl_rand_-hex_32

# ── Logs serveur ─────────────────────────────────
# Chemin absolu vers le fichier access.log
LOG_FILE_PATH=/var/log/nginx/access.log
# Format : nginx | apache
LOG_FORMAT=nginx

# ── Base de données ───────────────────────────────
DB_PATH=./spider-lens.db

# ── Alertes email ────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Email qui reçoit les alertes
ALERT_EMAIL=admin@example.com
# Nom de votre site (utilisé dans les emails)
SITE_NAME=Mon Site

# ── Seuils alertes ───────────────────────────────
# Nombre de nouvelles 404 par heure pour déclencher une alerte
ALERT_404_THRESHOLD=10
# Nombre de 5xx par heure pour alerte critique
ALERT_5XX_THRESHOLD=5
# Nombre de jours sans Googlebot avant alerte
ALERT_GOOGLEBOT_DAYS=7

# ── Rétention données ────────────────────────────
# Nombre de jours de logs à conserver en base
DATA_RETENTION_DAYS=90
